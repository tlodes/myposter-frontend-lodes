{
  "openapi": "3.0.0",
  "info": {
    "title": "MYPOSTER Job Interview API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://www.myposter.de"
    }
  ],
  "paths": {
    "/web-api/job-interview": {
      "get": {
        "responses": {
          "200": {
            "description": "Returns a list of blog posts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "$ref": "#/components/schemas/Message"
                    },
                    "payload": {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/BlogPost"
                          }
                        }
                      }
                    }
                  }
                },
                "example": {
                  "message": {
                    "status": "success",
                    "code": "frontend-exercise data fetched",
                    "text": "sucessfully fetched frontend-exercise data"
                  },
                  "payload": {
                    "data": [
                      {
                        "id": 1,
                        "author": "Special developer",
                        "title": "QA this year",
                        "dateAdded": "2024-08-06",
                        "images": {
                          "portrait": [
                            "https://picsum.photos/900/1600",
                            "https://picsum.photos/450/800"
                          ],
                          "landscape": [
                            "https://picsum.photos/1600/900",
                            "https://picsum.photos/800/450"
                          ]
                        },
                        "likes": 12
                      }
                    ]
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Message": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "code": {
            "type": "string"
          }
        }
      },
      "BlogPost": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "author": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "dateAdded": {
            "type": "string",
            "format": "date-time"
          },
          "images": {
            "$ref": "#/components/schemas/BlogImages"
          },
          "likes": {
            "type": "integer"
          }
        }
      },
      "BlogImages": {
        "type": "object",
        "properties": {
          "portrait": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "landscape": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}